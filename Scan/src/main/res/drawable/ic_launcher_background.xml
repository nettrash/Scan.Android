<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon background layer. Approximates the iOS app icon's deep
    radial blue: lighter (#1A237E) at the centre, darker (#0A1640) at the
    corners. Vector so it renders crisply at every DPI without needing
    per-density PNG variants.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="78"
                android:startColor="#1A237E"
                android:endColor="#0A1640" />
        </aapt:attr>
    </path>
</vector>
